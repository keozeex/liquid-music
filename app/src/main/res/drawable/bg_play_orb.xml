<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- هاله‌ی نئون بیرونی -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/neon_cyan_soft" />
        </shape>
    </item>
    <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="60dp"
                android:centerX="0.35"
                android:centerY="0.3"
                android:startColor="#33FFFFFF"
                android:centerColor="#0FFFFFFF"
                android:endColor="@color/glass_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_edge_bright" />
        </shape>
    </item>
</layer-list>
