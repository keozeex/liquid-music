<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#33FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="@color/neon_cyan_soft" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/steel" />
            <corners android:radius="29dp" />
        </shape>
    </item>
</layer-list>
