<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/abyss"
                android:centerColor="@color/navy"
                android:endColor="#070B13" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="260dp"
                android:startColor="@color/neon_cyan_soft"
                android:endColor="@color/transparent" />
        </shape>
        <size android:width="320dp" android:height="320dp" />
    </item>
</layer-list>
