<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss">

    <!-- هاله‌های نئون پس‌زمینه -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_splash"
        android:alpha="0.5"
        android:translationX="-80dp"
        android:translationY="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- نوار بالا -->
    <TextView
        android:id="@+id/eyebrow"
        style="@style/Text.Eyebrow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/nav_library"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/appTitle"
        style="@style/Text.Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/app_name"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/eyebrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- کارت جست‌وجوی شیشه‌ای -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            app:tint="@color/ink_dim" />

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@null"
            
            android:hint="@string/search_hint"
            android:textColorHint="@color/ink_dim"
            android:textColor="@color/ink_bright"
            android:textSize="13.5sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1" />

    </LinearLayout>

    <!-- دکمه‌ی اسکن خودکار -->
    <LinearLayout
        android:id="@+id/scanButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/searchBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_scan"
            app:tint="@color/neon_cyan" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            
            android:text="@string/action_scan"
            android:textColor="@color/ink_bright"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- وضعیت اسکن -->
    <TextView
        android:id="@+id/scanStatus"
        style="@style/Text.Subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:gravity="center"
        android:text="@string/scan_in_progress"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scanButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- لیست کتابخانه -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/trackList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/scanStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/miniPlayer" />

    <!-- حالت خالی -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scanStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/miniPlayer">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.5"
            android:src="@drawable/ic_wave" />

        <TextView
            style="@style/Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/empty_state_title"
            android:textSize="16sp" />

        <TextView
            style="@style/Text.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:gravity="center"
            android:text="@string/empty_state_subtitle" />

    </LinearLayout>

    <!-- مینی پلیر شیشه‌ای کف صفحه -->
    <LinearLayout
        android:id="@+id/miniPlayer"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="84dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="14dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/miniArt"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/miniTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                
                android:textColor="@color/ink_bright"
                android:textSize="13.5sp"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="505" />

            <TextView
                android:id="@+id/miniArtist"
                style="@style/Text.Subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Arctic Monkeys" />

        </LinearLayout>

        <ImageView
            android:id="@+id/miniPlayPause"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_play"
            app:tint="@color/neon_cyan" />

    </LinearLayout>

    <!-- نوار پایین شیشه‌ای -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navLibrary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_library" app:tint="@color/neon_cyan" />
            <TextView style="@style/Text.Eyebrow" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:text="@string/nav_library" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAlbums"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_album" app:tint="@color/ink_dim" />
            <TextView style="@style/Text.Eyebrow" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:text="@string/nav_albums" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navArtists"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_artist" app:tint="@color/ink_dim" />
            <TextView style="@style/Text.Eyebrow" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:text="@string/nav_artists" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPlaylists"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_playlist" app:tint="@color/ink_dim" />
            <TextView style="@style/Text.Eyebrow" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:text="@string/nav_playlists" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
