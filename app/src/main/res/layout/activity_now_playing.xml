<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <!-- نوار بالا -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_glass_card"
        android:padding="9dp"
        android:src="@drawable/ic_back"
        app:tint="@color/ink"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/nowPlayingLabel"
        style="@style/Text.Eyebrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/now_playing"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/btnMore"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_glass_card"
        android:padding="9dp"
        android:src="@drawable/ic_more"
        app:tint="@color/ink"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- قاب شیشه‌ای جلد آلبوم -->
    <FrameLayout
        android:id="@+id/coverFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_cover_frame"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.74"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toTopOf="@id/trackTitle"
        app:layout_constraintVertical_chainStyle="packed">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/albumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/steel_light"
            app:shapeAppearanceOverlay="@style/CoverImageShape"
            tools:src="@drawable/ic_album" />

    </FrameLayout>

    <TextView
        android:id="@+id/trackTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        
        android:gravity="center"
        android:textColor="@color/ink_bright"
        android:textSize="21sp"
        android:textStyle="normal"
        tools:text="505"
        app:layout_constraintTop_toBottomOf="@id/coverFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/trackArtist" />

    <TextView
        android:id="@+id/trackArtist"
        style="@style/Text.Subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:textSize="13.5sp"
        tools:text="Arctic Monkeys · Favourite Worst Nightmare"
        app:layout_constraintTop_toBottomOf="@id/trackTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressZone" />

    <!-- نوار پیشرفت موج‌دار -->
    <LinearLayout
        android:id="@+id/progressZone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/trackArtist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controls">

        <ProgressBar
            android:id="@+id/waveProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:max="1000"
            android:progress="380"
            android:progressDrawable="@drawable/progress_wave" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/timeElapsed"
                style="@style/Text.Subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                tools:text="1:42" />

            <TextView
                android:id="@+id/timeTotal"
                style="@style/Text.Subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textSize="11sp"
                tools:text="4:13" />

        </LinearLayout>

    </LinearLayout>

    <!-- کنترل‌های پخش -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/progressZone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomRow">

        <ImageView
            android:id="@+id/btnShuffle"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="18dp"
            android:padding="4dp"
            android:src="@drawable/ic_shuffle"
            app:tint="@color/ink_dim" />

        <ImageView
            android:id="@+id/btnPrev"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_prev"
            app:tint="@color/ink" />

        <FrameLayout
            android:id="@+id/btnPlayPause"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_play_orb">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                app:tint="@color/ink_bright" />

        </FrameLayout>

        <ImageView
            android:id="@+id/btnNext"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_next"
            app:tint="@color/ink" />

        <ImageView
            android:id="@+id/btnRepeat"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="18dp"
            android:padding="4dp"
            android:src="@drawable/ic_repeat"
            app:tint="@color/ink_dim" />

    </LinearLayout>

    <!-- ردیف پایین: کیفیت + بعدی در صف -->
    <LinearLayout
        android:id="@+id/bottomRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@drawable/bg_glass_card"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_glow" />

            <TextView
                style="@style/Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:text="@string/lossless_badge" />

        </LinearLayout>

        <View
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:id="@+id/btnFavorite"
            android:layout_width="44dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_glass_card"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_heart"
                app:tint="@color/neon_violet" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
