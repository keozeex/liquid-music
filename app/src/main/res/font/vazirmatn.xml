<?xml version="1.0" encoding="utf-8"?>
<!--
  خانواده فونت وزیرمتن - بهترین فونت فارسی متن‌باز برای رابط کاربری.
  فایل‌های .ttf را از فونت گوگل دانلود و در پوشه‌ی res/font قرار بده:
  https://fonts.google.com/specimen/Vazirmatn

  Vazirmatn font family — the standard open-source Persian UI font.
  Download the .ttf files from Google Fonts and place them in res/font:
  vazirmatn_regular.ttf, vazirmatn_medium.ttf, vazirmatn_semibold.ttf, vazirmatn_bold.ttf
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/vazirmatn_regular" />
    <font
        android:fontStyle="normal"
        android:fontWeight="500"
        android:font="@font/vazirmatn_medium" />
    <font
        android:fontStyle="normal"
        android:fontWeight="600"
        android:font="@font/vazirmatn_semibold" />
    <font
        android:fontStyle="normal"
        android:fontWeight="700"
        android:font="@font/vazirmatn_bold" />
</font-family>
