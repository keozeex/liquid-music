<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.LiquidGlass" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/abyss</item>
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorSecondary">@color/neon_violet</item>
        <item name="colorSurface">@color/steel</item>
        <item name="android:statusBarColor">@color/abyss</item>
        <item name="android:navigationBarColor">@color/abyss</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- فونت فارسی پیش‌فرض در کل اپلیکیشن -->
        <item name="android:fontFamily">@font/vazirmatn</item>
        <item name="fontFamily">@font/vazirmatn</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
    </style>

    <style name="Theme.LiquidGlass.Splash" parent="Theme.LiquidGlass">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.LiquidGlass.NowPlaying" parent="Theme.LiquidGlass">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowAnimationStyle">@style/Anim.NowPlaying</item>
    </style>

    <style name="Anim.NowPlaying" parent="android:Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_up_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_down_out</item>
    </style>

    <!-- تایپوگرافی -->
    <style name="Text.Title" parent="android:TextAppearance">
        <item name="android:fontFamily">@font/vazirmatn</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/ink_bright</item>
    </style>

    <style name="Text.Subtitle" parent="android:TextAppearance">
        <item name="android:fontFamily">@font/vazirmatn</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ink_dim</item>
    </style>

    <style name="Text.Eyebrow" parent="android:TextAppearance">
        <item name="android:fontFamily">@font/vazirmatn</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">@color/ink_dim</item>
    </style>

    <!-- دکمه‌ی شیشه‌ای گرد برای پلی -->
    <style name="GlassOrbButton">
        <item name="android:background">@drawable/bg_play_orb</item>
        <item name="android:elevation">12dp</item>
    </style>

    <style name="RoundedImage" parent="">
        <item name="cornerSize">14dp</item>
    </style>

    <style name="CoverImageShape" parent="">
        <item name="cornerSize">28dp</item>
    </style>


    <!-- کارت شیشه‌ای عمومی -->
    <style name="GlassCard">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:padding">14dp</item>
    </style>

</resources>
